<!-- PAGE HERO -->
<section class="page-hero" aria-labelledby="trainers-heading">
  <div class="page-hero__bg" style="background-image:url('/images/583A3282.webp'); background-position: center 40%;"></div>
  <div class="page-hero__overlay"></div>
  <div class="page-hero__content">
    <span class="section-label">Our Team</span>
    <h1 class="page-hero__title" id="trainers-heading">Meet your coaches</h1>
    <p class="page-hero__desc">Every trainer here is certified, experienced, and invested in your progress — not just your membership.</p>
  </div>
</section>

<!-- TRAINERS — full-bleed panel list -->
<section class="trainers-section" aria-label="Trainer profiles">
  {% for trainer in trainers %}
  <article class="trainer-panel" id="trainer-{{ trainer.id }}" aria-labelledby="{{ trainer.id }}-name">

    <div class="trainer-panel__img-wrap">
      <img
        src="{{ trainer.image }}"
        alt="{{ trainer.alt or trainer.name + ' — ' + trainer.title }}"
        width="{{ trainer.imageWidth }}"
        height="{{ trainer.imageHeight }}"
        loading="lazy"
        class="trainer-panel__img">
    </div>

    <div class="trainer-panel__body">
      <span class="section-label trainer-panel__role">{{ trainer.title }}</span>
      <h2 class="trainer-panel__name" id="{{ trainer.id }}-name">{{ trainer.name }}</h2>

      {% if trainer.specialties.length %}
      <div class="trainer-panel__specialties">
        {% for spec in trainer.specialties %}
        <span class="specialty-badge">{{ spec }}</span>
        {% endfor %}
      </div>
      {% endif %}

      <p class="trainer-panel__bio">{{ trainer.bio }}</p>

      {% if trainer.passion %}
      <p class="trainer-panel__section-label">My Passion</p>
      <p class="trainer-panel__bio">{{ trainer.passion }}</p>
      {% endif %}

      {% if trainer.community %}
      <p class="trainer-panel__section-label">My Community</p>
      <p class="trainer-panel__bio">{{ trainer.community }}</p>
      {% endif %}

      {% if trainer.certifications.length %}
      <p class="trainer-panel__section-label">Certifications</p>
      <ul class="trainer-panel__certs">
        {% for cert in trainer.certifications %}
        <li>{{ cert }}</li>
        {% endfor %}
      </ul>
      {% endif %}

      <div class="trainer-panel__social">
        <a href="{{ trainer.instagram }}" target="_blank" rel="noopener" aria-label="{{ trainer.name }} on Instagram">
          <i class="fab fa-instagram" aria-hidden="true"></i>
        </a>
        {% if trainer.facebook %}
        <a href="{{ trainer.facebook }}" target="_blank" rel="noopener" aria-label="{{ trainer.name }} on Facebook">
          <i class="fab fa-facebook" aria-hidden="true"></i>
        </a>
        {% endif %}
        <a href="#pt-inquiry" data-coach="{{ trainer.name }}" class="btn btn--primary btn--sm" style="margin-left:0.5rem;">
          Train with {{ trainer.name.split(' ')[0] }}
        </a>
      </div>
    </div>

  </article>
  {% endfor %}
</section>

<!-- CTA -->
<section class="cta-section has-grain">
