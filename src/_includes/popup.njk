<div class="popup" id="popup" role="dialog" aria-modal="true" aria-hidden="true" aria-label="Join The Gym of Tucson">
  <div class="popup__backdrop" data-popup-close></div>
  <div class="popup__card">

    <button class="popup__close" data-popup-close aria-label="Close">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>

    <div class="popup__accent" aria-hidden="true"></div>

    <div class="popup__body">
      <span class="popup__overline">BETTER EVERY DAY</span>
      <h2 class="popup__title">Your first 5 classes are on us.</h2>
      <p class="popup__desc">Join Tucson's #1 rated gym. Try 5 classes free — no pressure, no commitment, no credit card.</p>

      <a href="{{ booking.freeClasses5 }}"
         target="_blank"
         rel="noopener noreferrer"
         class="popup__cta btn btn--primary"
         data-popup-close>
        Claim 5 free classes <span class="btn-arrow">→</span>
      </a>

      <button class="popup__dismiss" data-popup-close>
        No thanks, I'll pay full price
      </button>
    </div>

    <div class="popup__skull" aria-hidden="true">
      <img src="/images/SkullGymlight.svg" alt="" width="200" height="200">
    </div>

  </div>
</div>
