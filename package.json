{
  "name": "gym-of-tucson-website",
  "version": "1.0.0",
  "description": "The Gym of Tucson — boutique strength training in Tucson, AZ. Static site built with Eleventy + Tailwind.",
  "private": true,
  "scripts": {
    "build": "npm run css && npx @11ty/eleventy",
    "css": "npx tailwindcss -i ./src/assets/css/styles.css -o ./src/assets/css/output.css --minify",
    "start": "concurrently \"npx tailwindcss -i ./src/assets/css/styles.css -o ./src/assets/css/output.css --watch\" \"npx @11ty/eleventy --serve\"",
    "dev": "npm run start"
  },
  "devDependencies": {
    "@11ty/eleventy": "^2.0.1",
    "autoprefixer": "^10.4.14",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.24",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.3.2"
  }
}
